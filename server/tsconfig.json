{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "../",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "../src/types/game.ts",
    "../src/types/mediapipe.d.ts",
    "../src/lib/gameConstants.ts",
    "../src/lib/gameConstants.server.ts",
    "../src/services/gameStateService.ts"
  ],
  "exclude": ["node_modules", "dist"]
}